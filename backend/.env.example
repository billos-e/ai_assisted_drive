# Copy this file to .env and fill in your local values.

# Clés à récupérer dans votre fichier credentials.json (Google Cloud Console)
GOOGLE_CLIENT_ID='your-google-client-id'
GOOGLE_CLIENT_SECRET='your-google-client-secret'

# Sera généré automatiquement par python scripts/generate_token.py
GOOGLE_TOKEN_JSON=''

# ID du dossier Google Drive à indexer
GOOGLE_DRIVE_ROOT_FOLDER_ID='your-drive-root-folder-id'
GEMINI_API_KEY='your-gemini-api-key'
GROQ_API_KEY='your-groq-api-key'
API_BASE_URL='http://127.0.0.1:8000'
CHROMA_PATH='data/chromadb'
REDIRECT_URL='http://localhost:8000/auth/google/callback'